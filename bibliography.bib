@article{morrisonOffloadingItemsMemory2020,
  title = {Offloading Items from Memory: Individual Differences in Cognitive Offloading in a Short-Term Memory Task},
  shorttitle = {Offloading Items from Memory},
  author = {Morrison, Alexandra B. and Richmond, Lauren L.},
  date = {2020-01-03},
  journaltitle = {Cognitive Research: Principles and Implications},
