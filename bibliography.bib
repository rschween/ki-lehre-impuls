@article{newtonPragmaticMasterList2020,
  title = {A {{Pragmatic Master List}} of {{Action Verbs}} for {{Bloom}}'s {{Taxonomy}}},
  author = {Newton, Philip M. and Da Silva, Ana and Peters, Lee George},
  date = {2020-07-10},
  journaltitle = {Frontiers in Education},
  shortjournal = {Front. Educ.},
  volume = {5},
  publisher = {Frontiers},
