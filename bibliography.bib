  title = {Single-Paper Meta-Analyses of the Effects of Spaced Retrieval Practice in Nine Introductory {{STEM}} Courses: Is the Glass Half Full or Half Empty?},
  shorttitle = {Single-Paper Meta-Analyses of the Effects of Spaced Retrieval Practice in Nine Introductory {{STEM}} Courses},
  author = {Bego, Campbell R. and Lyle, Keith B. and Ralston, Patricia A. S. and Immekus, Jason C. and Chastain, Raymond J. and Haynes, Lora D. and Hoyt, Lenore K. and Pigg, Rachel M. and Rabin, Shira D. and Scobee, Matthew W. and Starr, Thomas L.},
