Read\_Status\_Date: 2026-02-10T12:38:55.671Z}
}

@article{gerlichAIToolsSociety2025,
  title = {{{AI Tools}} in {{Society}}: {{Impacts}} on {{Cognitive Offloading}} and the {{Future}} of {{Critical Thinking}}},
